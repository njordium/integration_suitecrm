# Copy to docker/.env and adjust as needed. Every value has a sensible
# default in docker-compose.yml, so an empty .env still works.
#
# @Code Changes by: Kim Haverblad, 2026

# ---- Nextcloud ----
NC_VERSION=30
NC_PORT=8080
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=admin

# ---- SuiteCRM ----
SUITECRM_VERSION=8.10.1
CRM_PORT=8081
CRM_ADMIN_USER=admin
CRM_ADMIN_PASSWORD=admin

# ---- Shared OAuth2 client ----
OAUTH_CLIENT_ID=nc-dev-client
OAUTH_CLIENT_SECRET=nc-dev-secret
OAUTH_REDIRECT_URI=http://localhost:8080/apps/integration_suitecrm/oauth-callback
