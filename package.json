{
	"name": "njordium_suitecrm",
	"version": "2.4.0",
	"description": "SuiteCRM integration",
	"main": "index.js",
	"directories": {
		"test": "tests"
	},
	"scripts": {
		"verify:version": "node scripts/verify-version.js",
		"prebuild": "npm run verify:version",
		"predev": "npm run verify:version",
		"build": "NODE_ENV=production webpack --progress --config webpack.js",
		"dev": "NODE_ENV=development webpack --progress --config webpack.js",
		"watch": "NODE_ENV=development webpack --progress --watch --config webpack.js",
		"lint": "eslint --ext .js,.vue src",
		"lint:fix": "eslint --ext .js,.vue src --fix",
		"stylelint": "stylelint 'src/**/*.{css,scss,vue}' 'css/**/*.{css,scss}'",
		"stylelint:fix": "stylelint 'src/**/*.{css,scss,vue}' 'css/**/*.{css,scss}' --fix"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/njordium/integration_suitecrm"
	},
	"keywords": [
		"suitecrm"
	],
	"author": "Kim Haverblad (fork maintainer); Julien Veyssier <eneiluj@posteo.net> (original author)",
	"license": "AGPL-3.0",
	"bugs": {
		"url": "https://github.com/njordium/integration_suitecrm/issues"
	},
	"homepage": "https://github.com/njordium/integration_suitecrm",
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"engines": {
		"node": "^20.0.0",
		"npm": "^10.0.0"
	},
	"dependencies": {
		"@nextcloud/auth": "^2.6.0",
		"@nextcloud/axios": "^2.6.0",
		"@nextcloud/dialogs": "^7.4.0",
		"@nextcloud/initial-state": "^3.0.0",
		"@nextcloud/l10n": "^3.4.1",
		"@nextcloud/moment": "^1.3.0",
		"@nextcloud/router": "^3.1.0",
		"@nextcloud/vue": "^9.8.0",
		"vue": "^3.5.0",
		"vue-material-design-icons": "^5.3.1"
	},
	"devDependencies": {
		"@nextcloud/babel-config": "^1.3.0",
		"@nextcloud/browserslist-config": "^3.0.0",
		"@nextcloud/eslint-config": "^9.0.0",
		"@nextcloud/stylelint-config": "^3.2.2",
		"@nextcloud/webpack-vue-config": "^7.0.2",
		"terser-webpack-plugin": "^5.6.1"
	}
}
