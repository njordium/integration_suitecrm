{
	"name": "njordium/integration_suitecrm",
	"description": "SuiteCRM integration for Nextcloud",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"require": {
		"php": "^8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"phpstan/phpstan": "^1.11",
		"nextcloud/ocp": "dev-master"
	},
	"autoload": {
		"psr-4": {
			"OCA\\SuiteCRM\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\SuiteCRM\\Tests\\": "tests/php/"
		}
	},
	"scripts": {
		"test": "phpunit --configuration phpunit.xml",
		"stan": "phpstan analyse --configuration phpstan.neon"
	},
	"config": {
		"sort-packages": true
	}
}
