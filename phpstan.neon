parameters:
  level: 5
  paths:
    - lib
  excludePaths:
    # nextcloud/ocp's abstract App class does not fully resolve under phpstan; scanning Application.php produces spurious errors on parent::__construct.
    - lib/AppInfo/Application.php
  reportUnmatchedIgnoredErrors: false
  ignoreErrors:
    # Legacy properties from the julien-nc port that are set in the constructor
    # but only consumed elsewhere; not worth touching in a CI-focused pass.
    - '#Property .* is never read, only written\.#'
  